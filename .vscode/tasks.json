{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build TypeScript",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"options": {
				"cwd": "${workspaceFolder}/core/ui"
			},
			"group": "build",
			"problemMatcher": "$tsc"
		},
		{
			"label": "Configure CMake (JUCE)",
			"type": "shell",
			"command": "cmake",
			"args": [
				"-G",
				"Visual Studio 18 2026",
				"-A",
				"x64",
				"-S",
				"${workspaceFolder}/juce",
				"-B",
				"${workspaceFolder}/juce/builds"
			],
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Build SoundshedGuitar (JUCE) Debug",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"${workspaceFolder}/juce/builds",
				"--config",
				"Debug",
				"--target",
				"SoundshedGuitar_Standalone"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$msCompile"
		},
		{
			"label": "Build SoundshedGuitar (JUCE) Standalone Release",
			"dependsOn": [
				"Build TypeScript"
			],
			"dependsOrder": "sequence",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"${workspaceFolder}/juce/builds",
				"--config",
				"Release",
				"--target",
				"SoundshedGuitar_Standalone",
				"--parallel"
			],
			"group": "build",
			"problemMatcher": "$msCompile"
		},
		{
			"label": "Build SoundshedGuitar (JUCE) VST3 Release",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"${workspaceFolder}/juce/builds",
				"--config",
				"Release",
				"--target",
				"SoundshedGuitar_VST3",
				"--parallel"
			],
			"group": "build",
			"problemMatcher": "$msCompile"
		},
		{
			"label": "Build SoundshedGuitar (JUCE) Standalone+VST3 Release",
			"dependsOn": [
				"Build SoundshedGuitar (JUCE) Standalone Release",
				"Build SoundshedGuitar (JUCE) VST3 Release"
			],
			"dependsOrder": "sequence",
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Build All Release (JUCE)",
			"dependsOn": [
				"Build SoundshedGuitar (JUCE) Standalone+VST3 Release"
			],
			"dependsOrder": "sequence",
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Build All Tests",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"${workspaceFolder}/core/build",
				"--config",
				"Debug"
			],
			"group": "build",
			"problemMatcher": "$msCompile"
		},
		{
			"label": "Run All Tests",
			"type": "shell",
			"command": "ctest",
			"args": [
				"-C",
				"Debug",
				"--output-on-failure"
			],
			"options": {
				"cwd": "${workspaceFolder}/core/build"
			},
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "Run Fast Tests (No Benchmarks)",
			"type": "shell",
			"command": "ctest",
			"args": [
				"-C",
				"Debug",
				"--output-on-failure",
				"-LE",
				"benchmark"
			],
			"options": {
				"cwd": "${workspaceFolder}/core/build"
			},
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "Build SoundshedGuitar (JUCE Linux x64) Release",
			"type": "shell",
			"command": "bash",
			"args": [
				"${workspaceFolder}/build_linux.sh",
				"--arch",
				"x64",
				"--zip"
			],
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Build SoundshedGuitar (JUCE Linux arm64) Release",
			"type": "shell",
			"command": "bash",
			"args": [
				"${workspaceFolder}/build_linux.sh",
				"--arch",
				"arm64",
				"--zip"
			],
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Build SoundshedGuitar (JUCE Linux) Release",
			"dependsOn": [
				"Build SoundshedGuitar (JUCE Linux x64) Release",
				"Build SoundshedGuitar (JUCE Linux arm64) Release"
			],
			"dependsOrder": "sequence",
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Build SoundshedGuitar (JUCE Linux x64) Release + LV2",
			"type": "shell",
			"command": "bash",
			"args": [
				"${workspaceFolder}/build_linux.sh",
				"--arch",
				"x64",
				"--lv2",
				"--zip"
			],
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Build SoundshedGuitar (JUCE Linux arm64) Release + LV2",
			"type": "shell",
			"command": "bash",
			"args": [
				"${workspaceFolder}/build_linux.sh",
				"--arch",
				"arm64",
				"--lv2",
				"--zip"
			],
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Build SoundshedGuitar (JUCE Linux) Release + LV2",
			"dependsOn": [
				"Build SoundshedGuitar (JUCE Linux x64) Release + LV2",
				"Build SoundshedGuitar (JUCE Linux arm64) Release + LV2"
			],
			"dependsOrder": "sequence",
			"group": "build",
			"problemMatcher": []
		}
	]
}
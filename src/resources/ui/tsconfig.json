{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ES2019"],
    "strict": true,
    "noImplicitAny": true,
    "noEmitOnError": false,
    "outDir": "./dist",
    "rootDir": "./ts",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["./ts/**/*"],
  "exclude": ["./dist"]
}
